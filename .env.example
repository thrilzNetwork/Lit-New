# Database (Supabase / Vercel Postgres)
# Use the "Connection String" -> "URI" from Supabase Settings
POSTGRES_URL="postgres://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Cloudinary (Optional, for image uploads)
CLOUDINARY_URL=

# Session Secret (Any random string)
SESSION_SECRET="some-random-secret-key"
